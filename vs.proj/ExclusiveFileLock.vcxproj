<?xml version="1.0" encoding="utf-8"?>
<!--
  ExclusiveFileLock.vcxproj
  ══════════════════════════
  Visual Studio / MSBuild project file for the Exclusive File Lock Notepad++ plugin.
  Located in vs.proj\ to match the layout of the official Notepad++ plugin
  template (https://github.com/npp-plugins/plugintemplate).

  Targets
  ───────
    Release | x64   → 64-bit DLL  (for 64-bit Notepad++)
    Release | Win32 → 32-bit DLL  (for 32-bit Notepad++)

  Key settings explained
  ──────────────────────
  ConfigurationType = DynamicLibrary
      Produces a .dll, not an .exe.

  CharacterSet = Unicode
      Defines UNICODE + _UNICODE so TCHAR = wchar_t.
      Required by all modern Notepad++ versions.

  PlatformToolset = v145
      Uses the VS 2026 / Build Tools 2026 compiler.
      Change to v143 for VS 2022, v142 for VS 2019.

  RuntimeLibrary = MultiThreaded
      Links the CRT statically — no MSVCRT*.dll dependency at runtime.

  AdditionalIncludeDirectories = $(ProjectDir)..\src
      Allows #include "Scintilla.h" etc. to resolve from the src\ folder.

  ModuleDefinitionFile = ..\src\ExclusiveFileLock.def
      Forces undecorated export names so Notepad++ can find them via GetProcAddress().
      our .def file for clean export names

  TargetName = ExclusiveFileLock
      output file will be ExclusiveFileLock.dll

  IntDir and OutDir (explicit — required by name length)
      MSBuild's Microsoft.Cpp.MSVC.Toolset.Common.props applies a 16-character
      threshold when computing the default IntDir.  Project names longer than
      16 characters are silently replaced with a truncated form:
          $(ProjectName.Substring(0,8)).$(ProjectGuid.Substring(1,8))
      "ExclusiveFileLock" is 17 characters, so without explicit values MSBuild
      would produce "Exclusiv.A1B2C3D4\" instead of the full plugin name.
      The IntDir and OutDir PropertyGroups below pin the paths to the full name.
      The previous plugin name "FileLockPlugin" (14 chars) was under the
      threshold and did not need this workaround.

-->
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Release|Win32">
      <Configuration>Release</Configuration>
      <Platform>Win32</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
  </ItemGroup>

  <PropertyGroup Label="Globals">
    <ProjectGuid>{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}</ProjectGuid>
    <RootNamespace>ExclusiveFileLock</RootNamespace>
    <WindowsTargetPlatformVersion>10.0</WindowsTargetPlatformVersion>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />

  <!-- ── Release | Win32 ── -->
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|Win32'" Label="Configuration">
    <ConfigurationType>DynamicLibrary</ConfigurationType>
    <UseDebugLibraries>false</UseDebugLibraries>
    <PlatformToolset>v145</PlatformToolset>
    <CharacterSet>Unicode</CharacterSet>
    <WholeProgramOptimization>true</WholeProgramOptimization>
  </PropertyGroup>

  <!-- ── Release | x64 ── -->
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'" Label="Configuration">
    <ConfigurationType>DynamicLibrary</ConfigurationType>
    <UseDebugLibraries>false</UseDebugLibraries>
    <PlatformToolset>v145</PlatformToolset>
    <CharacterSet>Unicode</CharacterSet>
    <WholeProgramOptimization>true</WholeProgramOptimization>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />

  <!-- ── Output directories ── -->
  <!-- Explicit IntDir and OutDir are required because "ExclusiveFileLock"       -->
  <!-- (17 chars) exceeds the 16-char threshold in                               -->
  <!-- Microsoft.Cpp.MSVC.Toolset.Common.props, which would otherwise silently   -->
  <!-- truncate IntDir to "Exclusiv.A1B2C3D4\..." — see top-of-file comment.    -->
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|Win32'">
    <IntDir>ExclusiveFileLock\Win32\Release\</IntDir>
    <OutDir>Win32\Release\</OutDir>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'">
    <IntDir>ExclusiveFileLock\x64\Release\</IntDir>
    <OutDir>x64\Release\</OutDir>
  </PropertyGroup>

  <!-- ── Compiler settings (both platforms) ── -->
  <ItemDefinitionGroup>
    <!-- Resource compiler: needs src\ on the include path to resolve resource.h -->
    <ResourceCompile>
      <AdditionalIncludeDirectories>$(ProjectDir)..\src;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
    </ResourceCompile>
    <ClCompile>
      <PrecompiledHeader>NotUsing</PrecompiledHeader>
      <AdditionalIncludeDirectories>$(ProjectDir)..\src;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <WarningLevel>Level3</WarningLevel>
      <Optimization>MaxSpeed</Optimization>
      <!-- UNICODE and _UNICODE make TCHAR == wchar_t throughout -->
      <PreprocessorDefinitions>UNICODE;_UNICODE;WIN32;NDEBUG;_WINDOWS;_USRDLL;%(PreprocessorDefinitions)</PreprocessorDefinitions>
       <!-- Static runtime so the DLL has no external CRT dependency -->
      <RuntimeLibrary>MultiThreaded</RuntimeLibrary>
      <DisableSpecificWarnings>4201;4996</DisableSpecificWarnings>
      <!-- Treat source files as UTF-8 so Unicode literals compile correctly -->
      <AdditionalOptions>/utf-8 %(AdditionalOptions)</AdditionalOptions>
    </ClCompile>

    <!-- ── Linker settings ── -->
    <Link>
      <SubSystem>Windows</SubSystem>
      <ModuleDefinitionFile>$(ProjectDir)..\src\ExclusiveFileLock.def</ModuleDefinitionFile>
      <GenerateDebugInformation>false</GenerateDebugInformation>
      <LinkTimeCodeGeneration>UseLinkTimeCodeGeneration</LinkTimeCodeGeneration>
      <AdditionalDependencies>kernel32.lib;user32.lib;comctl32.lib;advapi32.lib;%(AdditionalDependencies)</AdditionalDependencies>
    </Link>
  </ItemDefinitionGroup>

  <!-- ── Source files ── -->
  <ItemGroup>
    <ClCompile Include="..\src\PluginDefinition.cpp" />
  </ItemGroup>

  <!-- ── Header files ── -->
  <ItemGroup>
    <ClInclude Include="..\src\PluginDefinition.h" />
    <ClInclude Include="..\src\PluginInterface.h" />
    <ClInclude Include="..\src\Scintilla.h" />
    <ClInclude Include="..\src\Sci_Position.h" />
    <ClInclude Include="..\src\Notepad_plus_msgs.h" />
    <ClInclude Include="..\src\resource.h" />
  </ItemGroup>

  <!-- ── Resource files ── -->
  <ItemGroup>
    <ResourceCompile Include="..\src\ExclusiveFileLock.rc" />
  </ItemGroup>

  <!-- ── Module definition ── -->
  <ItemGroup>
    <None Include="..\src\ExclusiveFileLock.def" />
  </ItemGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />

</Project>
